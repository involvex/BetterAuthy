{
  "compilerOptions": {
    "baseUrl": "./src",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "~*": ["./*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2019",
    "allowSyntheticDefaultImports": true,
    "types": ["vite-plugin-pwa/client", "vite/client"],
    "module": "ESNext",
    "lib": ["ES2019", "DOM"]
  },
  "include": ["src/**/*","eslint.config.ts"],
  "exclude": ["node_modules", "dist"]
}
